# ── Convoy Game API — environment variables ─────────────────────────────────
# Copy this to .env and fill in real values.  Never commit .env.

# CiviCRM REST API credentials (from CiviCRM Admin > API Credentials)
# Use http://127.0.0.1 as base to bypass Cloudflare when running on the .85 box.
CIVICRM_BASE_URL=http://127.0.0.1
CIVICRM_HOST=dev2.ssjeremiahobrien.org
CIVICRM_API_KEY=your_api_key_here
CIVICRM_SITE_KEY=your_site_key_here

# Server port (nginx proxy_pass to this)
PORT=3001

# CORS — origin allowed to POST to /api/missions
ALLOWED_ORIGIN=https://game.ssjeremiahobrien.org

# CiviCRM Activity Type ID for "Convoy Game Completed"
# Create it in CiviCRM Admin > Activity Types, then paste its numeric ID here.
# Defaults to 1 (Meeting) until the custom type is created.
ACTIVITY_TYPE_ID=1
